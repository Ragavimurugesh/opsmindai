# ==============================================================================
# OpsMind AI - Secure Environment Variables Template
# Copy this file to '.env' and populate with your actual secret credentials.
# NEVER commit the actual '.env' file containing secrets to version control.
# ==============================================================================

# FastAPI Server Mode
# Options: development, production, testing
ENVIRONMENT=development

# Live Supabase PostgreSQL Connection Parameters
# Replace '[YOUR-PASSWORD]' and '[YOUR-PROJECT-ID]' with values from Supabase settings.
# For Transaction pooling (Session mode/Port 5432 or 6543) or direct connection:
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres

# Supabase API Credentials
# Used for backend authorization validation and clients management.
SUPABASE_URL=https://[YOUR-PROJECT-ID].supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-public-key-here...

# FastAPI Security Configuration (JWT Token Secret)
# Generate a secure random hex key using: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_super_secret_jwt_generation_key_32_bytes_or_more

# Database Connection Pool Configurations (Optional Overrides)
# Connection limit per application instance thread
DB_POOL_SIZE=5
# Maximum number of connections to allow beyond pool_size when load spikes
DB_MAX_OVERFLOW=10
