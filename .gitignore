# ─────────────────────────────────────────────────────────────────────────────
# OpsMind AI — .gitignore
# Strict exclusion layout for Phase 1-6 repository tracking
# ─────────────────────────────────────────────────────────────────────────────

# ── OS Files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Python / Virtual Environments ─────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
ENV/
pip-log.txt
pip-delete-this-directory.txt
.ipynb_checkpoints/
.pytest_cache/

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
/frontend/node_modules/
/frontend/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Environment / Secret Variables ────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
supabase_keys.txt

# ── Databases / Datasets ──────────────────────────────────────────────────────
*.sqlite3
*.db
dataset/raw/*
!dataset/raw/.gitkeep
dataset/processed/*
!dataset/processed/.gitkeep
dataset/raw_data.csv

# ── ML Models / Artifacts ─────────────────────────────────────────────────────
*.pkl
*.joblib
*.h5
ml/saved_models/*.joblib
ml/saved_models/*.pkl
ml/saved_models/*.h5
ml/saved_models/*.json
!ml/saved_models/.gitkeep

# ── Kaggle Kernel / Competition Data ──────────────────────────────────────────
demand-forecasting-kernels-only/

# ── Build and Deployment Files ────────────────────────────────────────────────
dist/
build/
.vercel
.render
