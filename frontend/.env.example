# ─────────────────────────────────────────────────────────────────────────────
# OpsMind AI — Frontend Environment Variables
# Copy this file to `.env` (gitignored) and fill in your values.
# All variables MUST be prefixed with VITE_ to be accessible in the browser.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API URL ────────────────────────────────────────────────────────────
# Development (default — no need to set if running backend on localhost:8000)
VITE_API_URL=http://localhost:8000

# Production — uncomment and set to your live Render/Railway backend URL:
# VITE_API_URL=https://opsmind-ai-backend.onrender.com
